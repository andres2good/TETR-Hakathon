{
  "manifest_version": 3,
  "name": "NAVI — Voice Assistant",
  "version": "0.1.0",
  "description": "Control your browser by voice. Always listening. Powered by Claude AI.",

  "action": {
    "default_title": "NAVI Voice Assistant"
  },

  "side_panel": {
    "default_path": "sidepanel.html"
  },

  "background": {
    "service_worker": "background.js"
  },

  "permissions": ["activeTab", "scripting", "tabs", "sidePanel", "windows"],
  "host_permissions": ["<all_urls>"],

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ]
}
