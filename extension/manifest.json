{
  "manifest_version": 3,
  "name": "TETR — Voice Assistant",
  "version": "0.1.0",
  "description": "Control your browser by voice. Powered by Claude AI.",

  "action": {
    "default_popup": "popup.html",
    "default_title": "TETR Voice Assistant"
  },

  "permissions": ["activeTab", "scripting", "tabs"],
  "host_permissions": ["<all_urls>"],

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ]
}
