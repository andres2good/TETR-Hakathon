{
  "manifest_version": 3,
  "name": "Echo by Ecolocation",
  "version": "0.1.0",
  "description": "AI voice assistant for Chrome. Say 'Echo' to activate - it navigates, clicks, types, and reads the web for you. By Ecolocation.",

  "icons": {
    "16":  "icons/icon16.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "action": {
    "default_title": "Echo Voice Assistant",
    "default_icon": {
      "16":  "icons/icon16.png",
      "48":  "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },

  "side_panel": {
    "default_path": "sidepanel.html"
  },

  "background": {
    "service_worker": "background.js"
  },

  "permissions": ["activeTab", "scripting", "tabs", "sidePanel", "windows", "storage"],
  "host_permissions": ["<all_urls>"],

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ]
}
