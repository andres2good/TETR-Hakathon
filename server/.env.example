# ═══════════════════════════════════════════════
# TETR — Variables de Entorno
# Copia este archivo como .env y rellena los valores
# NUNCA subas .env a GitHub
# ═══════════════════════════════════════════════

# Servidor
PORT=3000
NODE_ENV=development
SERVER_URL=https://tu-servidor.com

# Anthropic (Claude Vision — cerebro del agente)
# console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-xxxxxxxx
CLAUDE_MODEL=claude-sonnet-4-6

# Deepgram (escucha al usuario)
# console.deepgram.com
DEEPGRAM_API_KEY=xxxxxxxx
DEEPGRAM_MODEL=nova-3

# Cartesia (voz del agente)
# play.cartesia.ai
CARTESIA_API_KEY=xxxxxxxx
CARTESIA_VOICE_ID=xxxxxxxx
CARTESIA_MODEL=sonic-3

# Supabase (base de datos)
# app.supabase.com → Settings → API
# Usar la clave "service_role" (NO la "anon") — el servidor necesita acceso completo
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=xxxxxxxx

# Clave secreta para que la app Android se conecte al backend
# Puede ser cualquier string largo y aleatorio
APP_SECRET_KEY=cambia-esto-por-algo-secreto

# Logs
LOG_LEVEL=debug
